{
  "name": "opencode-studio",
  "version": "1.0.0",
  "description": "A modern code editor built with Monaco and Electron",
  "author": "OpenCode Studio",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"wait-on dist/renderer/index.html && electron .\"",
    "dev:main": "tsc -p tsconfig.main.json -w",
    "dev:renderer": "vite build --watch --config vite.renderer.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build --config vite.renderer.ts",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@preact/preset-vite": "^2.10.5",
    "htm": "^3.1.1",
    "monaco-editor": "^0.52.0",
    "preact": "^10.24.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.opencode.studio",
    "productName": "OpenCode Studio",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.25.12": true
  }
}
